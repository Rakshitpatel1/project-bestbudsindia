---
import Layout from '../../layouts/Layout.astro';
import products from '../../data/products.json';

export function getStaticPaths() {
  return products.map(product => ({
    params: { id: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const related = products.filter(p => p.category === product.category && p.id !== product.id).slice(0, 2);
---

<Layout title={product.name} description={product.verdict}>

  <div class="container">

    <div class="breadcrumb">
      <a href="/">Home</a> ›
      <a href="/products">Products</a> ›
      <a href={`/products?category=${product.category}`}>{product.category}</a> ›
      <span>{product.name}</span>
    </div>

    <div class="product-hero">
      <div class="product-image">
        <img
          src={product.image}
          alt={product.name}
          onerror="this.onerror=null;this.src='/images/placeholder.svg'"
        />
      </div>

      <div class="product-info">
        <span class="category-badge">{product.category}</span>
        <h1>{product.name}</h1>

        <div class="meta-row">
          <div class="price-block">
            <span class="price">~₹{product.price.toLocaleString('en-IN')}</span>
            <span class="price-note">Approximate · Click below for current price</span>
          </div>
          <span class="rating">&#9733; {product.rating} / 5</span>
        </div>

        <p class="verdict-text">{product.verdict}</p>

        <a href={product.affiliateLink} target="_blank" rel="nofollow noopener" class="buy-btn">
          Check Price on Amazon ↗
        </a>
        <p class="affiliate-note">* Affiliate link — we may earn a small commission at no extra cost to you. Prices on Amazon may differ from shown.</p>
      </div>
    </div>

    <div class="product-details">

      <div class="specs-card">
        <h2>Full Specifications</h2>
        <table class="specs-table">
          <tbody>
            {Object.entries(product.specs).map(([key, value]) => (
              <tr>
                <td class="spec-key">{key.replace(/([A-Z])/g, ' $1').trim()}</td>
                <td class="spec-val">
                  {key === 'noiseCancellation' && value !== 'No'
                    ? <span class="spec-badge spec-good">{value}</span>
                    : key === 'noiseCancellation' && value === 'No'
                    ? <span class="spec-badge spec-no">{value}</span>
                    : value}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="pros-cons">
        <div class="pros">
          <h2>Pros</h2>
          <ul>
            {product.pros.map(pro => (
              <li><span class="icon-good">✓</span> {pro}</li>
            ))}
          </ul>
        </div>
        <div class="cons">
          <h2>Cons</h2>
          <ul>
            {product.cons.map(con => (
              <li><span class="icon-bad">✗</span> {con}</li>
            ))}
          </ul>
        </div>

        <div class="tags-section">
          <h2>Tags</h2>
          <div class="tags">
            {product.tags.map(tag => (
              <span class="tag">#{tag}</span>
            ))}
          </div>
        </div>
      </div>

    </div>

    {related.length > 0 && (
      <div class="related">
        <h2>Related Products</h2>
        <div class="related-grid">
          {related.map(p => (
            <a href={`/products/${p.id}`} class="related-card">
              <img
                src={p.image}
                alt={p.name}
                onerror="this.onerror=null;this.src='/images/placeholder.svg'"
              />
              <div class="related-info">
                <h3>{p.name}</h3>
                <span class="price-sm">~₹{p.price.toLocaleString('en-IN')}</span>
                <span class="related-rating">&#9733; {p.rating}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

  </div>

</Layout>

<style>
  .container { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }

  /* Breadcrumb */
  .breadcrumb {
    padding: 1.5rem 0 0;
    font-size: 0.82rem;
    color: var(--text-muted);
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    align-items: center;
  }
  .breadcrumb a { color: var(--accent); }
  .breadcrumb a:hover { text-decoration: underline; }

  /* Product hero */
  .product-hero {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 3rem;
    padding: 2rem 0;
    align-items: start;
  }

  .product-image {
    background: var(--bg-secondary);
    border-radius: var(--radius);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    min-height: 280px;
    position: sticky;
    top: 80px;
  }

  .product-image img {
    max-width: 100%;
    max-height: 240px;
    object-fit: contain;
  }

  .category-badge {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--accent);
    background: var(--accent-light);
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: inline-block;
  }

  .product-info h1 {
    font-size: 1.8rem;
    font-weight: 700;
    margin: 0.75rem 0 0.5rem;
    line-height: 1.3;
  }

  /* Price block */
  .meta-row {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .price-block { display: flex; flex-direction: column; gap: 2px; }

  .price {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--accent);
  }

  .price-note {
    font-size: 0.7rem;
    color: var(--text-muted);
    font-weight: 400;
  }

  .rating {
    font-size: 1rem;
    color: #f59e0b;
    font-weight: 600;
    padding-top: 4px;
  }

  .verdict-text {
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
    border-left: 3px solid var(--accent);
    padding-left: 1rem;
  }

  /* Buy button */
  .buy-btn {
    display: inline-block;
    background: #ff9900;
    color: white;
    padding: 0.85rem 2rem;
    border-radius: 8px;
    font-weight: 700;
    font-size: 1rem;
    transition: opacity 0.2s;
  }
  .buy-btn:hover { opacity: 0.88; }

  .affiliate-note {
    font-size: 0.72rem;
    color: var(--text-muted);
    margin-top: 0.6rem;
    line-height: 1.5;
    max-width: 380px;
  }

  /* Product details grid */
  .product-details {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 2rem;
    padding: 2rem 0;
    border-top: 1px solid var(--border);
  }

  .specs-card h2,
  .pros-cons h2 {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--text);
  }

  /* Specs table */
  .specs-table { width: 100%; border-collapse: collapse; }
  .specs-table tr { border-bottom: 1px solid var(--border); }
  .specs-table tr:last-child { border-bottom: none; }
  .specs-table tr:hover { background: var(--bg-secondary); }

  .spec-key {
    padding: 0.65rem 0.75rem 0.65rem 0;
    font-size: 0.82rem;
    color: var(--text-muted);
    text-transform: capitalize;
    width: 45%;
  }

  .spec-val {
    padding: 0.65rem 0;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text);
  }

  .spec-badge {
    font-size: 0.75rem;
    padding: 0.15rem 0.6rem;
    border-radius: 20px;
    font-weight: 600;
  }

  .spec-good { background: #dcfce7; color: #15803d; }
  .spec-no { background: #fee2e2; color: #b91c1c; }

  /* Pros / Cons */
  .pros ul, .cons ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 1.5rem;
  }

  .pros li, .cons li {
    font-size: 0.88rem;
    line-height: 1.5;
    display: flex;
    gap: 0.5rem;
    align-items: flex-start;
  }

  .icon-good { color: #16a34a; font-weight: 700; flex-shrink: 0; }
  .icon-bad { color: #dc2626; font-weight: 700; flex-shrink: 0; }

  /* Tags */
  .tags-section { margin-top: 0.5rem; }
  .tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.5rem; }
  .tag {
    font-size: 0.75rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    color: var(--text-muted);
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
  }

  /* Related products */
  .related { padding: 2rem 0; border-top: 1px solid var(--border); margin-bottom: 2rem; }
  .related h2 { font-size: 1rem; font-weight: 700; margin-bottom: 1rem; }

  .related-grid { display: flex; gap: 1rem; }

  .related-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.75rem 1rem;
    flex: 1;
    transition: border-color 0.2s, transform 0.2s;
    background: var(--bg);
  }

  .related-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .related-card img {
    width: 56px;
    height: 56px;
    object-fit: contain;
    flex-shrink: 0;
    background: var(--bg-secondary);
    border-radius: 6px;
    padding: 4px;
  }

  .related-info { flex: 1; }
  .related-info h3 { font-size: 0.88rem; font-weight: 600; margin-bottom: 0.25rem; line-height: 1.3; }

  .price-sm { font-size: 0.9rem; font-weight: 700; color: var(--accent); display: block; }
  .related-rating { font-size: 0.78rem; color: #f59e0b; }

  /* Responsive */
  @media (max-width: 700px) {
    .product-hero { grid-template-columns: 1fr; gap: 1.5rem; }
    .product-image { position: static; min-height: 200px; }
    .product-details { grid-template-columns: 1fr; }
    .related-grid { flex-direction: column; }
    .product-info h1 { font-size: 1.4rem; }
  }
</style>